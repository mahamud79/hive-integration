# Copy this file to ".env" and fill in your real values.
# NEVER commit .env — it contains your client secret.

# From the Hive Partner Portal (https://app.hive.co/partners/portal/)
HIVE_CLIENT_ID=your_client_id_here
HIVE_CLIENT_SECRET=your_client_secret_here

# Must EXACTLY match a redirect URI you registered in the Partner Portal.
# Local testing:     http://localhost:3000/oauth/callback   (used by `npm run authorize`)
# Deployed (Render):  https://YOUR-APP.onrender.com/oauth/callback   (used by the server's /oauth/start)
HIVE_REDIRECT_URI=http://localhost:3000/oauth/callback

# OAuth + API endpoints (defaults are correct per Hive Beta docs)
HIVE_AUTHORIZE_URL=https://app.hive.co/oauth/api/authorize/
HIVE_TOKEN_URL=https://api.hive.co/oauth/token/
HIVE_API_BASE=https://api.hive.co/v2

# Scopes your integration needs (space-separated)
HIVE_SCOPES=events:read events:write orders:read orders:write contacts:read contacts:write segments:read segments:write

# --- Collector server (npm start) ---
# Port the local collector listens on (Render sets PORT automatically)
PORT=8787
# Restrict which website origin may call the collector (use your real storefront in prod).
# Example: https://www.bingoloco.com  — leave as * only for local testing.
COLLECTOR_ALLOWED_ORIGIN=*
# Optional: absolute path for the token file (e.g. a mounted persistent disk on Render).
# TOKENS_FILE=/data/tokens.json

# --- Durable token storage (optional, recommended on Render free tier) ---
# Create a free database at https://upstash.com (Redis) and paste its REST creds.
# When both are set, tokens are stored in Redis and survive restarts/sleeps.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_rest_token
# TOKENS_REDIS_KEY=hive_tokens
